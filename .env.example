# ═══════════════════════════════════════
# PARKD — Environment Configuration
# ═══════════════════════════════════════
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Oracle Database
DB_USER=your_oracle_username
DB_PASSWORD=your_oracle_password
DB_CONNECT_STRING=localhost:1521/FREEPDB1

# Oracle Instant Client path (adjust for your OS)
# Windows: C:/oracle/instantclient_21_9
# Linux:   /opt/oracle/instantclient_21_9
ORACLE_CLIENT_PATH=

# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=parkd_super_secret_change_this_in_production
JWT_EXPIRES_IN=24h
